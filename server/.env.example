PORT=8080

# Provider order for /gpt/ask fallback chain
AI_PROVIDER_ORDER=gemini,groq,openrouter,openai
VISION_PROVIDER_ORDER=gemini,openrouter,openai
OCR_PROVIDER_ORDER=gemini,openrouter,openai

# Gemini (primary)
GOOGLE_API_KEY=your_google_ai_studio_key_here
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash

# OpenAI / ChatGPT (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# Groq (optional fallback)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (optional fallback)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_VISION_MODEL=openrouter/free
OPENROUTER_REFERER=https://your-project-homepage.example
